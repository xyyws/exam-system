<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.exam.paper.mapper.PaperRuleMapper">
    <resultMap id="BaseResultMap" type="com.exam.paper.entity.PaperRule">
        <id column="id" property="id"/>
        <result column="paper_id" property="paperId"/>
        <result column="rule_name" property="ruleName"/>
        <result column="total_score" property="totalScore"/>
        <result column="total_count" property="totalCount"/>
        <result column="remark" property="remark"/>
    </resultMap>

    <select id="selectByPaperId" resultMap="BaseResultMap">
        SELECT * FROM paper_rule WHERE paper_id = #{paperId}
    </select>

    <insert id="insert" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO paper_rule (paper_id, rule_name, total_score, total_count, remark)
        VALUES (#{paperId}, #{ruleName}, #{totalScore}, #{totalCount}, #{remark})
    </insert>

    <delete id="deleteByPaperId">
        DELETE FROM paper_rule WHERE paper_id = #{paperId}
    </delete>
</mapper>
