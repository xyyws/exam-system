<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.exam.question.mapper.QuestionOptionMapper">

    <resultMap id="QuestionOptionResultMap" type="com.exam.question.entity.QuestionOption">
        <id property="id" column="id"/>
        <result property="questionId" column="question_id"/>
        <result property="optionLabel" column="option_label"/>
        <result property="optionContent" column="option_content"/>
        <result property="isCorrect" column="is_correct"/>
        <result property="sortNo" column="sort_no"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <insert id="batchInsert">
        INSERT INTO question_option (
            question_id, option_label, option_content, is_correct, sort_no
        ) VALUES
        <foreach collection="options" item="item" separator=",">
            (
                #{item.questionId}, #{item.optionLabel}, #{item.optionContent}, #{item.isCorrect}, #{item.sortNo}
            )
        </foreach>
    </insert>

    <delete id="deleteByQuestionId">
        DELETE FROM question_option
        WHERE question_id = #{questionId}
    </delete>

    <select id="selectByQuestionId" resultMap="QuestionOptionResultMap">
        SELECT id, question_id, option_label, option_content, is_correct, sort_no, create_time
        FROM question_option
        WHERE question_id = #{questionId}
        ORDER BY sort_no ASC, id ASC
    </select>

</mapper>
